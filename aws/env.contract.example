# Required runtime identity
V2_ENV=paper
V2_RUNTIME_MODE=replay_batch
V2_RUNTIME_CONFIG=/app/Newtest/Breaker_Based/signal_model_v2/configs/v2_runtime_config.example.json
V2_RUN_ID=v2_aws_manual_run

# Data and artifact storage
V2_S3_BUCKET=replace-with-signal-system-bucket
V2_S3_PREFIX=signal_model_v2
V2_LOCAL_WORKDIR=/app/Newtest/Breaker_Based/signal_model_v2

# Market data provider
V2_CANDLE_PROVIDER=yfinance
V2_INTERVAL=1h
V2_UNIVERSE=original
V2_YFINANCE_PERIOD=730d

# Safety gates
V2_LIVE_TRADING_ENABLED=false
V2_ORDER_PLACEMENT_ENABLED=false
V2_MANUAL_REVIEW_REQUIRED=true

# Observability
V2_LOG_LEVEL=INFO
V2_CLOUDWATCH_LOG_GROUP=/signal-model-v2/runtime
